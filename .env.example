# Google Sheets API — pour la waitlist
# 1. Creer un projet Google Cloud: https://console.cloud.google.com
# 2. Activer l'API Google Sheets
# 3. Creer une cle API (ou un Service Account)
# 4. Creer un Google Sheet et noter l'ID (dans l'URL)
# 5. Renseigner ces valeurs ici (et dans Vercel > Settings > Environment Variables)

GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_API_KEY=your_api_key_here
