---
---

<section id="box" class="py-24 md:py-32 border-b border-white/[0.08]">
  <div class="max-w-[800px] mx-auto px-6 md:px-8 text-center">
    <div class="reveal">
      <p
        class="text-xs tracking-[3px] uppercase mb-4"
        style="font-family: var(--font-mono); color: var(--color-primary);"
      >
        Bientot
      </p>
      <h2
        class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        La Box<br />Decouverte
      </h2>
      <p
        class="text-lg mb-12 leading-relaxed"
        style="color: var(--color-text-secondary);"
      >
        Chaque mois, une selection surprise de produits camerounais livree chez
        vous. Saveurs, style, culture — un morceau du Cameroun dans votre boite
        aux lettres.
      </p>
    </div>

    <!-- Box preview -->
    <div
      class="reveal glass-panel rounded-[28px] p-8 md:p-12 max-w-lg mx-auto"
    >
      <!-- Gift box SVG icon -->
      <div class="flex justify-center mb-6">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="8" y="28" width="48" height="28" rx="3" stroke="var(--color-primary)" stroke-width="2" fill="none"/>
          <rect x="4" y="20" width="56" height="10" rx="3" stroke="var(--color-primary)" stroke-width="2" fill="none"/>
          <line x1="32" y1="20" x2="32" y2="56" stroke="var(--color-primary)" stroke-width="2"/>
          <path d="M32 20C32 20 32 12 24 10C16 8 18 16 22 18C26 20 32 20 32 20Z" stroke="var(--color-primary)" stroke-width="2" fill="none"/>
          <path d="M32 20C32 20 32 12 40 10C48 8 46 16 42 18C38 20 32 20 32 20Z" stroke="var(--color-primary)" stroke-width="2" fill="none"/>
        </svg>
      </div>
      <h3
        class="text-xl mb-3"
        style="font-family: var(--font-display); font-weight: 700;"
      >
        Une box, trois univers
      </h3>
      <div class="flex justify-center gap-6 mb-6">
        <div class="text-center">
          <div class="flex justify-center mb-1">
            <!-- Flame / spice icon -->
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 3C14 3 8 10 8 16C8 19.3 10.7 22 14 22C17.3 22 20 19.3 20 16C20 10 14 3 14 3Z" stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 22C14 22 11 19 11 16.5C11 14.5 14 12 14 12C14 12 17 14.5 17 16.5C17 19 14 22 14 22Z" stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p
            class="text-[10px] tracking-[1px] uppercase"
            style="font-family: var(--font-mono); color: var(--color-text-tertiary);"
          >
            Saveurs
          </p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-1">
            <!-- Shirt / style icon -->
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 4L5 7L7 13L9 12V24H19V12L21 13L23 7L18 4" stroke="var(--color-primary)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 4C10 4 11 7 14 7C17 7 18 4 18 4" stroke="var(--color-primary)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p
            class="text-[10px] tracking-[1px] uppercase"
            style="font-family: var(--font-mono); color: var(--color-text-tertiary);"
          >
            Style
          </p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-1">
            <!-- Palette / art icon -->
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 3C8 3 3 8 3 14C3 20 8 25 14 25C15.1 25 16 24.1 16 23C16 22.5 15.8 22.1 15.5 21.7C15.2 21.4 15 21 15 20.5C15 19.4 15.9 18.5 17 18.5H19.5C22.5 18.5 25 16 25 13C25 7.5 20 3 14 3Z" stroke="var(--color-sky)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="9.5" cy="11.5" r="1.5" fill="var(--color-accent)"/>
              <circle cx="14.5" cy="8.5" r="1.5" fill="var(--color-secondary)"/>
              <circle cx="19.5" cy="11.5" r="1.5" fill="var(--color-primary)"/>
            </svg>
          </div>
          <p
            class="text-[10px] tracking-[1px] uppercase"
            style="font-family: var(--font-mono); color: var(--color-text-tertiary);"
          >
            Art
          </p>
        </div>
      </div>
      <p class="text-sm" style="color: var(--color-text-tertiary);">
        Inscrivez-vous a la waitlist pour etre informe du lancement.
      </p>
    </div>
  </div>
</section>
