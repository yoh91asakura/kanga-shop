---
---

<section id="art" class="py-24 md:py-32 border-b border-white/[0.08]">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Visual — real photo (left on desktop) -->
      <div class="reveal h-[400px] rounded-[28px] overflow-hidden border border-white/[0.08] order-2 md:order-1">
        <img
          src="/images/art-bijoux.png"
          alt="Art camerounais — tableaux de peintres, statuettes en bois, poteries, collier en or et bracelets ethniques"
          class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
          loading="lazy"
        />
      </div>

      <!-- Text -->
      <div class="reveal order-1 md:order-2">
        <p
          class="text-xs tracking-[3px] uppercase mb-4"
          style="font-family: var(--font-mono); color: var(--color-primary);"
        >
          Art & Culture
        </p>
        <h2
          class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
          style="font-family: var(--font-display); font-weight: 900;"
        >
          L'ame artistique<br />du Cameroun
        </h2>
        <p
          class="text-lg mb-8 leading-relaxed"
          style="color: var(--color-text-secondary);"
        >
          Tableaux de peintres camerounais, objets d'art, bijoux ethniques. Chaque
          piece est une fenetre ouverte sur la creativite camerounaise.
        </p>
        <div class="flex flex-wrap gap-3">
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Tableaux de peintre</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Objets d'art</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Bijoux ethniques</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
