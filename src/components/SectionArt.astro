---
---

<section id="art" class="section-light py-24 md:py-32">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Visual (left on desktop) -->
      <div class="reveal h-[400px] rounded-[28px] overflow-hidden border border-black/[0.08] shadow-md order-2 md:order-1">
        <img
          src="/images/art-bijoux.webp"
          alt="Art camerounais — tableaux, statuettes, poteries, collier en or et bracelets ethniques"
          class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
          loading="lazy"
        />
      </div>

      <!-- Text -->
      <div class="reveal order-1 md:order-2">
        <p class="text-xs tracking-[3px] uppercase mb-4" style="font-family: var(--font-mono); color: var(--color-accent);">
          Art & Culture
        </p>
        <h2 class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6" style="font-family: var(--font-display); font-weight: 900; color: var(--color-bg-primary);">
          L'ame artistique<br />du Cameroun
        </h2>
        <p class="text-lg mb-8 leading-relaxed" style="color: rgba(28,26,20,0.65);">
          Tableaux de peintres camerounais, objets d'art, bijoux ethniques. Chaque
          piece est une fenetre ouverte sur la creativite camerounaise.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-4 py-2 rounded-full text-sm bg-black/[0.05] border border-black/[0.08]" style="color: rgba(28,26,20,0.65);">Tableaux de peintre</span>
          <span class="px-4 py-2 rounded-full text-sm bg-black/[0.05] border border-black/[0.08]" style="color: rgba(28,26,20,0.65);">Objets d'art</span>
          <span class="px-4 py-2 rounded-full text-sm bg-black/[0.05] border border-black/[0.08]" style="color: rgba(28,26,20,0.65);">Bijoux ethniques</span>
        </div>
      </div>
    </div>
  </div>
</section>
