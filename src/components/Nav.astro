---
interface Props {
  activePage?: 'home' | 'shop' | 'box' | '';
}

const { activePage = '' } = Astro.props;

const isHome = activePage === 'home';

// Build link hrefs - on home page use anchors, on other pages use absolute paths
const saveursHref = isHome ? '/#saveurs' : '/#saveurs';
const style237Href = isHome ? '/#style237' : '/#style237';
const artHref = isHome ? '/#art' : '/#art';
const boxHref = '/box';
const shopHref = '/shop';
const waitlistHref = isHome ? '/#waitlist' : '/#waitlist';

// For the home page, use # anchors without the leading /
const saveursHrefHome = '#saveurs';
const style237HrefHome = '#style237';
const artHrefHome = '#art';
const waitlistHrefHome = '#waitlist';

type NavLink = {
  href: string;
  label: string;
  active: boolean;
};

const desktopLinks: NavLink[] = [
  { href: isHome ? saveursHrefHome : saveursHref, label: 'Saveurs', active: false },
  { href: isHome ? style237HrefHome : style237Href, label: 'Style 237', active: false },
  { href: isHome ? artHrefHome : artHref, label: 'Art & Culture', active: false },
  { href: boxHref, label: 'La Box', active: activePage === 'box' },
  { href: shopHref, label: 'Shop', active: activePage === 'shop' },
];

const mobileLinks: NavLink[] = [
  { href: isHome ? saveursHrefHome : saveursHref, label: 'Saveurs', active: false },
  { href: isHome ? style237HrefHome : style237Href, label: 'Style 237', active: false },
  { href: isHome ? artHrefHome : artHref, label: 'Art & Culture', active: false },
  { href: boxHref, label: 'La Box Decouverte', active: activePage === 'box' },
  { href: shopHref, label: 'Shop', active: activePage === 'shop' },
];

const waitlistHrefFinal = isHome ? waitlistHrefHome : waitlistHref;

// On non-home pages, nav starts with glass-panel; on home, starts transparent
const navInitialClass = isHome
  ? 'fixed top-0 left-0 right-0 z-50 transition-all duration-500'
  : 'fixed top-0 left-0 right-0 z-50 glass-panel transition-all duration-500';
const navInitialBg = isHome ? 'background: transparent;' : '';
---

<nav id="navbar" class={navInitialClass} style={navInitialBg}>
  <div class="max-w-[1200px] mx-auto px-6 md:px-8 h-16 flex items-center justify-between">
    <a
      href="/"
      class="text-lg"
      style="font-family: var(--font-display); font-weight: 900;"
    >
      <span style="color: var(--color-primary);">Kanga</span><span
        style="color: var(--color-text-tertiary);">-</span
      >Shop
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {desktopLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm transition-colors hover:text-[var(--color-primary)]"
          style={link.active
            ? 'color: var(--color-primary); font-family: var(--font-body); font-weight: 600;'
            : 'color: var(--color-text-secondary); font-family: var(--font-body);'}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a
        href={waitlistHrefFinal}
        class="px-5 py-2 rounded-full text-sm transition-all duration-300 hover:-translate-y-0.5"
        style="background: var(--color-primary); color: var(--color-bg-primary); font-family: var(--font-display); font-weight: 700;"
      >
        Waitlist
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="block w-5 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-text-primary);" id="bar1"></span>
        <span class="block w-5 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-text-primary);" id="bar2"></span>
        <span class="block w-3.5 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-text-primary);" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300" style="max-height: 0;">
    <div class="px-6 py-6 flex flex-col gap-4" style="background: rgba(28, 26, 20, 0.85); backdrop-filter: blur(32px); -webkit-backdrop-filter: blur(32px);">
      {mobileLinks.map((link) => (
        <a
          href={link.href}
          class="text-base transition-colors hover:text-[var(--color-primary)] mobile-link"
          style={link.active
            ? 'color: var(--color-primary); font-family: var(--font-body); font-weight: 600;'
            : 'color: var(--color-text-secondary); font-family: var(--font-body);'}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Navbar: transparent at top, glass when scrolled
  const navbar = document.getElementById('navbar')!;
  const scrollThreshold = 80;

  function updateNav() {
    if (window.scrollY > scrollThreshold) {
      navbar.classList.add('glass-panel');
      navbar.style.background = '';
    } else {
      // If the nav didn't start with glass-panel (home page), go transparent
      // Check if the nav was initially transparent by looking for the data attribute
      if (navbar.dataset.initialTransparent === 'true') {
        navbar.classList.remove('glass-panel');
        navbar.style.background = 'transparent';
      }
    }
  }

  // Determine if nav should start transparent (home page behavior)
  // If navbar doesn't already have glass-panel on load and scroll is at top, it's the home page
  const startsTransparent = !navbar.classList.contains('glass-panel') || window.scrollY <= scrollThreshold;
  // More reliable: check if glass-panel was NOT in the initial server-rendered class list
  // We detect this by checking if background was set to transparent initially
  if (navbar.style.background === 'transparent') {
    navbar.dataset.initialTransparent = 'true';
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  let menuOpen = false;

  menuBtn.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.style.maxHeight = menuOpen ? '300px' : '0';
    const bars = menuBtn.querySelectorAll('span');
    if (menuOpen) {
      bars[0].style.transform = 'rotate(45deg) translate(4px, 4px)';
      bars[1].style.opacity = '0';
      bars[2].style.transform = 'rotate(-45deg) translate(3px, -3px)';
      bars[2].style.width = '20px';
    } else {
      bars[0].style.transform = '';
      bars[1].style.opacity = '1';
      bars[2].style.transform = '';
      bars[2].style.width = '14px';
    }
  });

  // Close menu on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.style.maxHeight = '0';
      const bars = menuBtn.querySelectorAll('span');
      bars[0].style.transform = '';
      bars[1].style.opacity = '1';
      bars[2].style.transform = '';
      bars[2].style.width = '14px';
    });
  });
</script>
