---
---

<section class="relative min-h-screen flex flex-col justify-end overflow-hidden">
  <!-- Background: video with image fallback -->
  <div class="absolute inset-0">
    <!-- Video background — autoplay, muted, loops -->
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/images/hero-cameroun.png"
      class="w-full h-full object-cover"
      id="hero-video"
    >
      <source src="/images/video-kanga.mp4" type="video/mp4" />
      <!-- Fallback: if video can't play, poster image shows -->
    </video>

    <!-- Image fallback for slow connections / no-video -->
    <img
      src="/images/hero-cameroun.png"
      alt="Paysage camerounais — arbre majestueux devant le Mont Cameroun"
      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000"
      id="hero-fallback"
      loading="eager"
      fetchpriority="high"
    />

    <!-- Gradient overlay -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, rgba(28,26,20,0.05) 0%, rgba(28,26,20,0.15) 30%, rgba(28,26,20,0.5) 60%, rgba(28,26,20,0.85) 85%, rgba(28,26,20,0.95) 100%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1200px] mx-auto w-full px-6 md:px-8 pb-16 md:pb-24 pt-48">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-5 py-2 rounded-full mb-8 text-xs tracking-[2px] uppercase"
      style="background: rgba(200,150,58,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(200,150,58,0.3); color: var(--color-primary); font-family: var(--font-mono);"
    >
      Le Cameroun chez vous
    </div>

    <!-- Title -->
    <h1
      class="text-5xl md:text-7xl lg:text-[110px] leading-[0.92] tracking-[-0.04em] mb-6 max-w-4xl"
      style="font-family: var(--font-display); font-weight: 900; text-shadow: 0 2px 20px rgba(0,0,0,0.3);"
    >
      <span style="color: var(--color-primary);">Kanga</span><span
        style="color: rgba(250,245,238,0.35);">-</span
      >Shop
    </h1>

    <!-- Tagline -->
    <p
      class="text-lg md:text-xl mb-10 max-w-lg leading-relaxed"
      style="color: rgba(250,245,238,0.85); font-family: var(--font-body); text-shadow: 0 1px 8px rgba(0,0,0,0.3);"
    >
      Saveurs authentiques. Mode 237. Art contemporain.<br />
      Une selection familiale, livree en France.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="#waitlist"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-[15px] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
        style="background: var(--color-primary); color: #1C1A14; font-family: var(--font-display); font-weight: 700; box-shadow: 0 4px 24px rgba(200,150,58,0.25);"
      >
        Rejoindre la waitlist
      </a>
      <a
        href="#saveurs"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-[15px] transition-all duration-300 hover:-translate-y-0.5"
        style="background: rgba(250,245,238,0.1); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(250,245,238,0.15); font-family: var(--font-display); font-weight: 700; color: var(--color-text-primary);"
      >
        Decouvrir les univers
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="rgba(250,245,238,0.35)"
      stroke-width="2"
    >
      <path d="M12 5v14M19 12l-7 7-7-7" />
    </svg>
  </div>

  <!-- Video/fallback logic -->
  <script>
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const fallback = document.getElementById('hero-fallback') as HTMLImageElement;

    if (video) {
      // When video can play, hide the fallback image
      video.addEventListener('canplay', () => {
        fallback.style.opacity = '0';
      }, { once: true });

      // If video fails to load, keep fallback visible
      video.addEventListener('error', () => {
        fallback.style.opacity = '1';
        video.style.display = 'none';
      });

      // For slow connections: if video hasn't loaded after 4s, keep fallback
      setTimeout(() => {
        if (video.readyState < 3) {
          fallback.style.opacity = '1';
        }
      }, 4000);
    }
  </script>
</section>
