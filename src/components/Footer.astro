---
---

<footer class="py-16 border-t border-white/[0.08]">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <h3
          class="text-2xl mb-4"
          style="font-family: var(--font-display); font-weight: 900;"
        >
          <span style="color: var(--color-primary);">Kanga</span><span
            style="color: var(--color-text-tertiary);">-</span
          >Shop
        </h3>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          Un projet familial ne entre le Cameroun et la France. La meilleure
          selection de produits camerounais authentiques, livree chez vous.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4
          class="text-sm tracking-[2px] uppercase mb-4"
          style="font-family: var(--font-mono); color: var(--color-primary);"
        >
          Univers
        </h4>
        <ul class="space-y-2">
          <li>
            <a href="#saveurs" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              Saveurs
            </a>
          </li>
          <li>
            <a href="#style237" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              Style 237
            </a>
          </li>
          <li>
            <a href="#art" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              Art & Culture
            </a>
          </li>
          <li>
            <a href="#box" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              La Box Decouverte
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4
          class="text-sm tracking-[2px] uppercase mb-4"
          style="font-family: var(--font-mono); color: var(--color-primary);"
        >
          Legal
        </h4>
        <ul class="space-y-2">
          <li>
            <a href="/mentions-legales" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              Mentions legales
            </a>
          </li>
          <li>
            <a href="/mentions-legales#confidentialite" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary);">
              Politique de confidentialite
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-white/[0.08] text-center">
      <p
        class="text-xs"
        style="color: var(--color-text-tertiary); font-family: var(--font-mono);"
      >
        &copy; 2026 Kanga-Shop. Fait avec amour entre le Cameroun et la France.
      </p>
    </div>
  </div>
</footer>
