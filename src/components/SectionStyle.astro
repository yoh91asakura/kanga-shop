---
---

<section id="style237" class="py-24 md:py-32 border-b border-white/[0.08]">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Text -->
      <div class="reveal">
        <p
          class="text-xs tracking-[3px] uppercase mb-4"
          style="font-family: var(--font-mono); color: var(--color-primary);"
        >
          Style 237
        </p>
        <h2
          class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
          style="font-family: var(--font-display); font-weight: 900;"
        >
          L'identite<br />vestimentaire<br />camerounaise
        </h2>
        <p
          class="text-lg mb-8 leading-relaxed"
          style="color: var(--color-text-secondary);"
        >
          Du boubou traditionnel aux chemisettes style 237, en passant par les
          maillots des Lions Indomptables. La fierte camerounaise se porte.
        </p>
        <div class="flex flex-wrap gap-3">
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Boubou homme</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Chemisette 237</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Maillots de foot</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Cabas femme</span
          >
          <span
            class="glass px-4 py-2 rounded-full text-sm"
            style="color: var(--color-text-secondary);">Sacs style femme</span
          >
        </div>
      </div>

      <!-- Visual — real photo -->
      <div class="reveal h-[400px] rounded-[28px] overflow-hidden border border-white/[0.08]">
        <img
          src="/images/mode-237.png"
          alt="Mode camerounaise — maillot Lions Indomptables, boubous plies, cabas en raphia, sac en cuir et bracelet"
          class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
