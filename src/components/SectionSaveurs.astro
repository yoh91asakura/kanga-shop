---
---

<section id="saveurs" class="py-24 md:py-32 border-b border-white/[0.08]">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <!-- Header -->
    <div class="reveal mb-16">
      <p
        class="text-xs tracking-[3px] uppercase mb-4"
        style="font-family: var(--font-mono); color: var(--color-primary);"
      >
        Saveurs
      </p>
      <h2
        class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        Les tresors<br />du terroir camerounais
      </h2>
      <p class="text-lg max-w-xl" style="color: var(--color-text-secondary);">
        Du poivre de Penja IGP au cafe des hauts plateaux, chaque produit raconte
        une histoire de savoir-faire et de tradition.
      </p>
    </div>

    <!-- Product grid with real photos -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Epices & Poivre -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/epices-variees.png"
            alt="Epices camerounaises — gingembre, cannelle, muscade, poivre de Penja dans des bols artisanaux"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Produit star
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Poivre de Penja & Epices
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Premier produit africain a obtenir une IGP. Poivre blanc, gingembre,
            cannelle, muscade — les saveurs qui font la cuisine camerounaise.
          </p>
        </div>
      </div>

      <!-- Cacao -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/cacao-feves.png"
            alt="Cabosses et feves de cacao du Cameroun dans un panier tisse artisanal"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Terroir
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Cacao & Mambo Chocolat
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Feves de cacao du Sud Cameroun et le mythique Mambo chocolat — la
            gourmandise camerounaise par excellence.
          </p>
        </div>
      </div>

      <!-- Huiles -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/epices-huiles.png"
            alt="Huile de palme, huile de palmistes et beurre de karite — produits traditionnels camerounais"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Tradition
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Huiles & Beurre de karite
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Huile de palme, de karite, de palmistes, de ndjansang. Le beurre de
            karite pur — pour la cuisine et la beaute.
          </p>
        </div>
      </div>

      <!-- Graines -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/graines-mortier.png"
            alt="Graines et haricots camerounais dans des bocaux en verre avec pilon traditionnel"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Essentiels
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Graines & Legumineuses
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Arachides crues et grillees, haricots rouges et blancs, nyebe. Les
            bases de la cuisine camerounaise.
          </p>
        </div>
      </div>

      <!-- Produits frais -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/produits-frais.png"
            alt="Arachides, bananes plantain, patates douces et manioc — produits frais camerounais"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Du marche
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Cafe & Produits du terroir
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Cafe pur arabica des hauts plateaux, arachides fraiches, et les
            ingredients incontournables de la table camerounaise.
          </p>
        </div>
      </div>

      <!-- Boissons -->
      <div
        class="reveal glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)]"
      >
        <div class="h-56 overflow-hidden">
          <img
            src="/images/boissons-cameroun.png"
            alt="Bieres et boissons camerounaises — Castel, Beaufort, jus de fruits, sur un marche africain"
            class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <p
            class="text-[10px] tracking-[2px] uppercase mb-2"
            style="font-family: var(--font-mono); color: var(--color-primary);"
          >
            Rafraichissement
          </p>
          <h3
            class="text-xl mb-2"
            style="font-family: var(--font-display); font-weight: 700;"
          >
            Boissons & Bieres
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            Top grenadine, Top ananas, Tampico, et les bieres camerounaises :
            Castel, Beaufort, Magna.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
