---
---

<section id="saveurs" class="section-light py-24 md:py-32">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8">
    <!-- Header -->
    <div class="reveal mb-16">
      <p
        class="text-xs tracking-[3px] uppercase mb-4"
        style="font-family: var(--font-mono); color: var(--color-accent);"
      >
        Saveurs
      </p>
      <h2
        class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
        style="font-family: var(--font-display); font-weight: 900; color: #1C1A14;"
      >
        Les tresors<br />du terroir camerounais
      </h2>
      <p class="text-lg max-w-xl" style="color: rgba(28,26,20,0.65);">
        Du poivre de Penja IGP au cafe des hauts plateaux, chaque produit raconte
        une histoire de savoir-faire et de tradition.
      </p>
    </div>

    <!-- Product grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Epices & Poivre -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/epices-variees.webp" alt="Epices camerounaises" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Produit star</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Poivre de Penja & Epices</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Premier produit africain a obtenir une IGP. Poivre blanc, gingembre, cannelle, muscade.</p>
        </div>
      </div>

      <!-- Cacao -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/cacao-feves.webp" alt="Cacao du Cameroun" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Terroir</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Cacao & Mambo Chocolat</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Feves de cacao du Sud Cameroun et le mythique Mambo chocolat.</p>
        </div>
      </div>

      <!-- Huiles -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/epices-huiles.webp" alt="Huiles camerounaises" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Tradition</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Huiles & Beurre de karite</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Huile de palme, de karite, de palmistes, de ndjansang. Beurre de karite pur.</p>
        </div>
      </div>

      <!-- Graines -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/graines-mortier.webp" alt="Graines camerounaises" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Essentiels</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Graines & Legumineuses</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Arachides, haricots rouges, nyebe. Les bases de la cuisine camerounaise.</p>
        </div>
      </div>

      <!-- Produits frais -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/produits-frais.webp" alt="Produits frais camerounais" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Du marche</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Cafe & Produits du terroir</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Cafe pur arabica des hauts plateaux et les ingredients incontournables.</p>
        </div>
      </div>

      <!-- Boissons -->
      <div class="reveal rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 bg-white/80 border border-black/[0.06] hover:border-[var(--color-primary)] shadow-sm hover:shadow-md">
        <div class="h-56 overflow-hidden">
          <img src="/images/boissons-cameroun.webp" alt="Boissons camerounaises" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-[10px] tracking-[2px] uppercase mb-2" style="font-family: var(--font-mono); color: var(--color-accent);">Rafraichissement</p>
          <h3 class="text-xl mb-2" style="font-family: var(--font-display); font-weight: 700; color: #1C1A14;">Boissons & Bieres</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(28,26,20,0.6);">Top grenadine, Tampico, et les bieres camerounaises : Castel, Beaufort, Magna.</p>
        </div>
      </div>
    </div>
  </div>
</section>
