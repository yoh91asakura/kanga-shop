---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SectionSaveurs from '../components/SectionSaveurs.astro';
import SectionStyle from '../components/SectionStyle.astro';
import SectionArt from '../components/SectionArt.astro';
import SectionBox from '../components/SectionBox.astro';
import SectionManifeste from '../components/SectionManifeste.astro';
import SectionImpact from '../components/SectionImpact.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Kanga-Shop — La maison de lifestyle camerounais"
  description="Premiere maison de lifestyle camerounais. Saveurs, mode 237, beaute naturelle, art — curates avec amour. Rejoignez la waitlist."
>
  <Nav activePage="home" />

  <Hero />
  <SectionManifeste />
  <SectionSaveurs />
  <SectionStyle />
  <SectionArt />
  <SectionBox />
  <SectionImpact />

  <!-- Waitlist Section -->
  <section id="waitlist" class="section-light py-24 md:py-32">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 text-center">
      <div class="reveal mb-12">
        <h2
          class="text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] mb-6"
          style="font-family: var(--font-display); font-weight: 900; color: var(--color-bg-primary);"
        >
          Rejoignez<br />l'aventure
        </h2>
        <p class="text-lg" style="color: rgba(28,26,20,0.65);">
          Soyez parmi les premiers a decouvrir Kanga-Shop.
        </p>
      </div>
      <div class="reveal">
        <WaitlistForm />
      </div>
    </div>
  </section>

  <Footer />
</Layout>
