---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { products, categories } from '../../data/products';
---

<Layout
  title="Shop — Kanga-Shop"
  description="Decouvrez notre catalogue de produits camerounais : epices, huiles, mode 237, art et bijoux ethniques."
>
  <!-- Navigation (same as index) -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 glass-panel" style="background: '';">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 h-16 flex items-center justify-between">
      <a href="/" class="text-lg" style="font-family: var(--font-display); font-weight: 900;">
        <span style="color: var(--color-primary);">Kanga</span><span style="color: var(--color-text-tertiary);">-</span>Shop
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/#saveurs" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary); font-family: var(--font-body);">Saveurs</a>
        <a href="/#style237" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary); font-family: var(--font-body);">Style 237</a>
        <a href="/#art" class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-secondary); font-family: var(--font-body);">Art & Culture</a>
        <a href="/shop" class="text-sm transition-colors" style="color: var(--color-primary); font-family: var(--font-body); font-weight: 600;">Shop</a>
      </div>
      <a href="/#waitlist" class="px-5 py-2 rounded-full text-sm transition-all duration-300 hover:-translate-y-0.5" style="background: var(--color-primary); color: #1C1A14; font-family: var(--font-display); font-weight: 700;">
        Waitlist
      </a>
    </div>
  </nav>

  <!-- Shop Header -->
  <section class="pt-32 pb-12 border-b border-white/[0.08]">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <p class="text-xs tracking-[3px] uppercase mb-4" style="font-family: var(--font-mono); color: var(--color-primary);">
        Catalogue
      </p>
      <h1 class="text-4xl md:text-6xl leading-[1.1] tracking-[-0.02em] mb-4" style="font-family: var(--font-display); font-weight: 900;">
        Notre selection
      </h1>
      <p class="text-lg max-w-xl" style="color: var(--color-text-secondary);">
        Les meilleurs produits camerounais, selectionnes avec soin. Inscrivez-vous a la waitlist pour etre informe de la disponibilite.
      </p>
    </div>
  </section>

  <!-- Filters -->
  <section class="py-6 border-b border-white/[0.08] sticky top-16 z-40" style="background: var(--color-bg-primary);">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <div class="flex flex-wrap gap-3" id="filters">
        <button
          class="filter-btn active px-5 py-2.5 rounded-full text-sm transition-all duration-300"
          data-category="all"
          style="font-family: var(--font-display); font-weight: 600;"
        >
          Tout ({products.length})
        </button>
        {Object.entries(categories).map(([key, cat]) => {
          const count = products.filter(p => p.category === key).length;
          return (
            <button
              class="filter-btn px-5 py-2.5 rounded-full text-sm transition-all duration-300"
              data-category={key}
              style="font-family: var(--font-display); font-weight: 600;"
            >
              {cat.emoji} {cat.label} ({count})
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="py-12">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="product-grid">
        {products.map((product) => (
          <a
            href={`/shop/${product.id}`}
            class="product-card glass rounded-[20px] overflow-hidden transition-all duration-400 hover:-translate-y-1 hover:border-[var(--color-primary)] block"
            data-category={product.category}
          >
            <!-- Image -->
            <div class="h-48 overflow-hidden relative">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                loading="lazy"
              />
              {product.badge && (
                <span
                  class="absolute top-3 right-3 px-3 py-1 rounded-full text-[11px] tracking-[1px] uppercase"
                  style="background: var(--color-primary); color: #1C1A14; font-family: var(--font-display); font-weight: 700;"
                >
                  {product.badge}
                </span>
              )}
            </div>

            <!-- Body -->
            <div class="p-5">
              <p
                class="text-[10px] tracking-[2px] uppercase mb-1.5"
                style="font-family: var(--font-mono); color: var(--color-primary);"
              >
                {categories[product.category].label}
              </p>
              <h3 class="text-base mb-1.5" style="font-family: var(--font-display); font-weight: 700;">
                {product.name}
              </h3>
              <p class="text-xs leading-relaxed mb-4" style="color: var(--color-text-secondary);">
                {product.description}
              </p>

              <!-- Price + CTA -->
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-xl" style="font-family: var(--font-display); font-weight: 900; color: var(--color-primary);">
                    {product.price.toFixed(2).replace('.', ',')}
                  </span>
                  <span class="text-xs ml-1" style="color: var(--color-text-tertiary); font-family: var(--font-mono);">
                    EUR / {product.unit}
                  </span>
                </div>
                <span
                  class="px-4 py-2 rounded-full text-xs transition-all duration-300"
                  style="background: var(--color-primary); color: #1C1A14; font-family: var(--font-display); font-weight: 700;"
                >
                  Voir
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="empty-state" class="hidden text-center py-24">
        <p class="text-4xl mb-4">🔍</p>
        <p class="text-lg" style="font-family: var(--font-display); font-weight: 700;">Aucun produit dans cette categorie</p>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 border-t border-white/[0.08]">
    <div class="max-w-[800px] mx-auto px-6 md:px-8 text-center">
      <h2 class="text-2xl md:text-3xl mb-4" style="font-family: var(--font-display); font-weight: 900;">
        Bientot disponible
      </h2>
      <p class="text-base mb-8" style="color: var(--color-text-secondary);">
        Les produits arrivent bientot. Inscrivez-vous pour etre informe du lancement et beneficier d'offres exclusives.
      </p>
      <a
        href="/#waitlist"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-[15px] transition-all duration-300 hover:-translate-y-0.5"
        style="background: var(--color-primary); color: #1C1A14; font-family: var(--font-display); font-weight: 700; box-shadow: 0 4px 24px rgba(200,150,58,0.25);"
      >
        Rejoindre la waitlist
      </a>
    </div>
  </section>

  <Footer />

  <!-- Filter logic -->
  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll('.product-card') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-state')!;

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = (btn as HTMLElement).dataset.category;

        // Update active state
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter products
        let visibleCount = 0;
        productCards.forEach((card) => {
          if (category === 'all' || card.dataset.category === category) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Show/hide empty state
        emptyState.classList.toggle('hidden', visibleCount > 0);
      });
    });
  </script>

  <!-- Filter button styles -->
  <style>
    .filter-btn {
      background: rgba(250, 245, 238, 0.06);
      border: 1px solid rgba(250, 245, 238, 0.1);
      color: var(--color-text-secondary);
    }
    .filter-btn:hover {
      background: rgba(250, 245, 238, 0.1);
      border-color: rgba(250, 245, 238, 0.2);
    }
    .filter-btn.active {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: #1C1A14;
    }
  </style>
</Layout>
